# ─── KAKOA environment variables (see packages/config/src/env.ts) ───
# Copy to .env.local and fill in. Required vars are marked; the rest are
# optional in Phase 0/1 (integrations run against in-repo mocks).

# ── Core (REQUIRED) ─────────────────────────────────────────────────
# Postgres connection string (Supabase pooled URL in hosted envs)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/kakoa
# Absolute public origin of the storefront; feeds canonicals/sitemap (REQUIRED)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Secret pepper mixed into OTP hashes; min 32 chars (REQUIRED)
OTP_PEPPER=change-me-to-a-random-string-of-32-plus-chars
# Secret for signing session cookies/tokens; min 32 chars (REQUIRED)
SESSION_SECRET=change-me-to-a-random-string-of-32-plus-chars
# Deployment environment: local | preview | staging | production (REQUIRED)
APP_ENV=local

# ── Razorpay (optional until payments go live) ──────────────────────
# Razorpay API key id (rzp_test_... in staging)
RAZORPAY_KEY_ID=
# Razorpay API key secret
RAZORPAY_KEY_SECRET=
# Secret configured on the Razorpay webhook endpoint (HMAC of raw body)
RAZORPAY_WEBHOOK_SECRET=

# ── Shiprocket (optional until fulfilment goes live) ────────────────
# Shiprocket API user email (for token auth)
SHIPROCKET_EMAIL=
# Shiprocket API user password
SHIPROCKET_PASSWORD=
# Shared secret sent as x-api-key on Shiprocket webhooks
SHIPROCKET_WEBHOOK_TOKEN=

# ── MSG91 SMS/OTP (optional; mocked locally) ────────────────────────
# MSG91 account auth key
MSG91_AUTH_KEY=
# MSG91 DLT-approved OTP template id
MSG91_OTP_TEMPLATE_ID=

# ── Resend email (optional; mocked locally) ─────────────────────────
# Resend API key
RESEND_API_KEY=
# From address for transactional email (SPF/DKIM/DMARC verified domain)
EMAIL_FROM=orders@kakoa.example

# ── Inngest (optional; local dev server needs no keys) ──────────────
# Inngest event key for sending events
INNGEST_EVENT_KEY=
# Inngest signing key for the serve endpoint
INNGEST_SIGNING_KEY=

# ── Observability (optional) ────────────────────────────────────────
# Sentry DSN for error reporting
SENTRY_DSN=
