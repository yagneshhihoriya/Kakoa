{
  "name": "kakoa",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:generate": "pnpm --filter @kakoa/db db:generate",
    "db:migrate": "pnpm --filter @kakoa/db db:migrate",
    "db:seed": "pnpm --filter @kakoa/db db:seed"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "packageManager": "pnpm@9.15.9"
}
